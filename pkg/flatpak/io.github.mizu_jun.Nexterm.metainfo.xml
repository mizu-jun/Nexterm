<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.mizu_jun.Nexterm</id>
  <name>Nexterm</name>
  <summary>GPU-accelerated terminal multiplexer with SSH, SFTP, and Lua scripting</summary>
  <description>
    <p>
      Nexterm is a modern, GPU-accelerated terminal multiplexer built in Rust.
      It supports SSH connections, SFTP file transfers, Lua scripting for automation,
      and WASM plugins for extensibility.
    </p>
    <p>Features:</p>
    <ul>
      <li>GPU-accelerated rendering via wgpu</li>
      <li>SSH / SFTP support</li>
      <li>Lua scripting and status bar widgets</li>
      <li>WASM plugin system</li>
      <li>Kitty graphics protocol</li>
      <li>Floating and tiling pane layouts</li>
      <li>256-color and True Color support</li>
    </ul>
  </description>
